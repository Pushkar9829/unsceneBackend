  "_instructions": {
    "purpose": "Integration test fixture for the UnsceneAI product-cue AI service.",
    "spec": "See ../AI_PRODUCT_CUE_SERVICE.md for full API contract.",
    "howToUse": [
      "1. POST analyzeJobRequest body to your POST /v1/analyze/jobs endpoint.",
      "2. Download videoUrl and imageUrl fields over HTTPS (public CloudFront URLs).",
      "3. When done, POST expectedCallbackSuccessReference shape to callbackUrl.",
      "4. Compare your generated cues against expectedCallbackSuccessReference (ground truth from production seed data). Timestamps need not match exactly; structure and productId mapping must be valid."
    ],
    "notes": [
      "productCues are NOT sent in the job request — your service must produce them.",
      "Both episodes currently share the same video file (~23s VTO demo clip).",
      "Replace callbackUrl and jobId when testing against staging."
    ]
  },
