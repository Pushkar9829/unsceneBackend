# Copy to src/.env and fill in values. Never commit src/.env.

NODE_ENV=production
PORT=5000

# Database (use authenticated URI in production)
MONGO_URI=mongodb://user:password@host:27017/unscene_ai?authSource=admin

# Auth — generate a long random string for JWT_SECRET
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# AWS S3 + CloudFront
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CLOUDFRONT_DOMAIN=

# Admin seed (change password before first deploy)
DEFAULT_ADMIN_NAME=Super Admin
DEFAULT_ADMIN_EMAIL=admin@unscene.ai
DEFAULT_ADMIN_PASSWORD=

# OTP (Msg91)
MSG91_AUTH_KEY=
MSG91_FLOW_ID=

# Disable demo login in production
DEMO_OTP_ENABLED=false

# AI product-cue service
AI_INGEST_ENABLED=true
AI_SERVICE_URL=https://your-ai-service.example.com
AI_CALLBACK_PUBLIC_BASE_URL=https://api.unscene.in

# Optional AI auth (leave unset if your AI service has no auth)
# AI_SERVICE_API_KEY=
# AI_WEBHOOK_SECRET=

# Optional extra CORS origins (comma-separated)
# CORS_ORIGINS=https://admin.unscene.in
